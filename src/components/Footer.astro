---
import {
	facebookUrl,
	googleReviewUrl,
	instagramUrl,
	mapsPlaceUrl,
	officeAddressLines,
} from '../constants/site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const tourPackages = [
	{ title: 'Mathura Vrindavan 1 Day Tour', href: `${base}/tours/mathura-vrindavan-1-day` },
	{ title: 'Mathura Vrindavan 2 Day Tour', href: `${base}/tours/mathura-vrindavan-2-day` },
	{ title: 'Mathura Vrindavan 3 Day Tour', href: `${base}/tours/mathura-vrindavan-3-day` },
	{ title: 'Mathura Vrindavan Agra 3 Day Tour', href: `${base}/tours/mathura-vrindavan-agra-3-day` },
	{ title: 'Agra 1 Day Tour', href: `${base}/tours/agra-tour` },
	{ title: 'Agra Fatehpur Sikri Tour', href: `${base}/tours/agra-fatehpur-sikri` },
];

const quickLinks = [
	{ title: 'Home', href: `${base}/` },
	{ title: 'About Us', href: `${base}/about` },
	{ title: 'Contact', href: `${base}/contact` },
	{ title: 'Airport Taxi', href: `${base}/taxi/airport-taxi` },
	{ title: 'Taxi Service', href: `${base}/taxi/mathura-to-delhi` },
];
---

<footer style="background-color: var(--primary-dark);" class="py-10 text-white">
	<div class="mx-auto max-w-6xl px-4">
		<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
			<div>
				<img src={`${base}/images/logo.png`} alt="Braj Go" class="h-16 w-auto sm:h-20" />
				<p class="mt-4 text-sm text-white/70">
					Your trusted partner for tours and taxi services in Mathura, Vrindavan & Agra.
				</p>
				<div class="mt-4 flex flex-wrap gap-3 text-sm">
					<a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="text-white/80 hover:text-white" aria-label="Instagram">Instagram</a>
					<span class="text-white/40" aria-hidden="true">·</span>
					<a href={facebookUrl} target="_blank" rel="noopener noreferrer" class="text-white/80 hover:text-white" aria-label="Facebook">Facebook</a>
					<span class="text-white/40" aria-hidden="true">·</span>
					<a href={googleReviewUrl} target="_blank" rel="noopener noreferrer" class="text-white/80 hover:text-white">Review us on Google</a>
				</div>
			</div>

			<div>
				<h4 class="font-bold">Tour Packages</h4>
				<ul class="mt-4 space-y-2 text-sm text-white/70">
					{tourPackages.map((item) => (
						<li><a href={item.href} class="hover:text-white">{item.title}</a></li>
					))}
				</ul>
			</div>

			<div>
				<h4 class="font-bold">Quick Links</h4>
				<ul class="mt-4 space-y-2 text-sm text-white/70">
					{quickLinks.map((item) => (
						<li><a href={item.href} class="hover:text-white">{item.title}</a></li>
					))}
				</ul>
			</div>

			<div>
				<h4 class="font-bold">Contact Us</h4>
				<ul class="mt-4 space-y-2 text-sm text-white/70">
					<li>Call: +91 88825 85969</li>
					<li><a href="mailto:dheerendrasingh7072@gmail.com" class="hover:text-white">dheerendrasingh7072@gmail.com</a></li>
					<li>WhatsApp: +91 89238 97072</li>
					<li><a href={mapsPlaceUrl} target="_blank" rel="noopener noreferrer" class="hover:text-white">{officeAddressLines}</a></li>
				</ul>
			</div>
		</div>

		<div class="mt-10 border-t border-white/20 pt-6 text-center text-sm text-white/60">
			© 2026 Braj Go Tours and Travels. All rights reserved.
		</div>
	</div>
</footer>
